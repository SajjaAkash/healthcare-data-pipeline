PROJECT_NAME=healthcare-data-pipeline
ENVIRONMENT=dev
AIRFLOW_SCHEDULE=@daily
AZURE_LOCATION=eastus2
AZURE_RESOURCE_GROUP=rg-healthcare-data-platform
AZURE_STORAGE_ACCOUNT=sthealthcareanalytics
ADLS_BRONZE_CONTAINER=bronze
ADLS_SILVER_CONTAINER=silver
ADLS_GOLD_CONTAINER=gold
KEY_VAULT_NAME=kv-healthcare-data-platform
USE_AZURE_DATABRICKS=true
AZURE_DRY_RUN=true
DATABRICKS_WORKSPACE_URL=https://adb-1234567890123456.7.azuredatabricks.net
DATABRICKS_BRONZE_JOB_ID=1001
DATABRICKS_SILVER_JOB_ID=1002
DATABRICKS_GOLD_JOB_ID=1003
PATIENT_API_URL=https://example.com/api/patients
CLAIMS_API_URL=https://example.com/api/claims
APPOINTMENTS_API_URL=https://example.com/api/appointments
FRESHNESS_SLA_HOURS=24
SOURCE_SYSTEM_NAME=clinical-ops-demo
